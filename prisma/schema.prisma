datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id              String    @id @default(cuid())
  username        String    @unique
  email           String?
  passwordHash    String
  name            String?
  credits         Decimal   @default(0) @db.Decimal(12, 4)
  status          String    @default("ACTIVE")    // ACTIVE, SUSPENDED, BANNED
  suspendedAt     DateTime?
  suspendReason   String?
  costPerMessage  Decimal   @default(14) @db.Decimal(12, 4)
  dailySendLimit  Int       @default(10000)
  maxCampaignSize    Int       @default(5000)
  smsProvider        String?   // 유저 배정 발송 라인 (infobip|smsto|txg). null = 전역 기본 폴백
  telegramId         String?   @unique  // 텔레그램 아이디 (선택). 가입 시 또는 관리자 수정으로 입력
  failedLoginCount   Int       @default(0)
  lockedUntil        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  logs            SmsLog[]
  campaigns       SmsCampaign[]
  transactions    Transaction[]
  creditLedger    CreditLedger[]
  templates       MessageTemplate[]
  usdtDeposits    UsdtDeposit[]
  addressBooks    AddressBook[]
}

model SmsCampaign {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])

  name            String?
  senderId        String?  // 발신번호 (Alphanumeric Sender ID, 최대 11자)
  messageBody     String
  messageType     String   @default("TRANSACTIONAL") // TRANSACTIONAL, AD

  status          String   @default("DRAFT") // DRAFT, QUEUED, SCHEDULED, SENDING, COMPLETED, CANCELLED, FAILED
  totalRecipients Int      @default(0)
  processedCount  Int      @default(0)
  deliveredCount  Int      @default(0)
  failedCount     Int      @default(0)

  costPerMessage  Decimal  @default(14) @db.Decimal(12, 4)
  estimatedCost   Decimal  @default(0)    @db.Decimal(12, 4)
  dynamicBatchSize Int?
  tempFailureStreak Int    @default(0)
  cooldownUntil   DateTime?
  scheduledAt     DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  logs            SmsLog[]

  @@index([userId, createdAt])
  @@index([status, updatedAt])
}

model SmsLog {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  campaignId    String?
  campaign      SmsCampaign? @relation(fields: [campaignId], references: [id])
  targetNumber  String
  messageBody   String
  status        String    @default("PENDING") // PENDING, SENT, RETRY_PENDING, DELIVERED, FAILED
  cost          Decimal   @default(0) @db.Decimal(12, 4)
  messageId     String?   @unique // 프로바이더가 발급한 메시지 ID
  providerName   String?   // 발송 시 사용된 프로바이더명 (infobip, smsto, txg 등) — 전달률 집계에 사용
  providerStatus String?
  providerError  String?
  networkName    String?   // 통신사명 (Infobip DLR에서 추출 → HLR 보강 시 정확값으로 덮어씀)
  networkCode    String?   // MCC+MNC 코드 (예: "450 05" = SKT)
  hlrCheckedAt   DateTime? // HLR Lookup 보강 완료 시각 — 값이 있으면 재조회 대상에서 제외 (중복 과금 방지)
  retryCount     Int       @default(0)
  nextRetryAt    DateTime?
  pollRetryCount Int       @default(0) // 레거시 TXG HTTP 폴링 카운터 (SMPP 전환 후 신규 경로에서는 사용하지 않음)
  createdAt     DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([campaignId, createdAt])
  @@index([status, createdAt])
  @@index([status, nextRetryAt])
  @@index([userId, status])
  @@index([providerName, status, createdAt]) // 프로바이더별 전달률 집계 + TXG 폴링 대상 조회
}

// HLR Lookup 캐시 — 발송 후 Infobip Number Lookup으로 조회한 실제 가입 통신사 정보를 번호별로 저장.
// 30일 TTL 캐시 (lookedUpAt 기준)로 동일 번호 재발송 시 재조회 비용 0.
model HlrLookup {
  id           String   @id @default(cuid())
  phone        String   @unique          // E.164 정규화 번호 (캐시 키)
  mccMnc       String?                   // HLR이 보고한 실제 통신사 MCCMNC
  carrierName  String?                   // mccMnc → 매핑한 통신사명 (SKT/KT/LG U+)
  countryCode  String?                   // ISO 3166-1 alpha-2 국가 코드
  ported       Boolean  @default(false)  // 번호이동(MNP) 여부
  reachable    String?                   // 도달 가능 상태: ACTIVE / ABSENT / DEAD / UNKNOWN
  rawResponse  Json?                     // Infobip 원응답 (감사/디버깅용)
  lookedUpAt   DateTime @default(now())  // 30일 TTL 판정 기준 시각
  updatedAt    DateTime @updatedAt

  @@index([lookedUpAt])
}

model Transaction {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  amount        Decimal   @db.Decimal(12, 4)
  type          String    // DEPOSIT, WITHDRAWAL
  description   String?
  createdAt     DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([type, createdAt])
}

// ===== 관리자 시스템 =====

model AdminUser {
  id                  String    @id @default(cuid())
  username            String    @unique
  email               String?
  passwordHash        String
  name                String
  role                String    @default("VIEWER")    // SUPER_ADMIN, ADMIN, SUPPORT, VIEWER
  status              String    @default("ACTIVE")    // ACTIVE, LOCKED, DISABLED
  mfaSecret           String?
  mfaEnabled          Boolean   @default(false)
  mfaBackupCodes      String[]  @default([])
  allowedIps          String[]  @default([])
  failedLoginCount    Int       @default(0)
  lockedUntil         DateTime?
  passwordChangedAt   DateTime  @default(now())
  previousPasswords   String[]  @default([])
  dailyCreditLimit    Decimal   @default(5000000) @db.Decimal(12, 4)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  lastLoginAt         DateTime?
  createdById         String?
  createdBy           AdminUser?  @relation("AdminCreator", fields: [createdById], references: [id])
  createdAdmins       AdminUser[] @relation("AdminCreator")
  sessions            AdminSession[]
  auditLogs           AuditLog[]

  @@index([role, status])
}

model AdminSession {
  id              String    @id @default(cuid())
  adminId         String
  admin           AdminUser @relation(fields: [adminId], references: [id], onDelete: Cascade)
  sessionToken    String    @unique
  ipAddress       String
  userAgent       String?
  expiresAt       DateTime
  lastActivityAt  DateTime  @default(now())
  mfaVerified     Boolean   @default(false)
  sudoUntil       DateTime?
  createdAt       DateTime  @default(now())

  @@index([sessionToken])
  @@index([adminId])
  @@index([expiresAt])
}

model AuditLog {
  id            String    @id @default(cuid())
  timestamp     DateTime  @default(now())
  adminId       String
  admin         AdminUser @relation(fields: [adminId], references: [id])
  adminEmail    String
  action        String
  targetType    String
  targetId      String?
  previousValue Json?
  newValue      Json?
  reason        String
  ipAddress     String
  userAgent     String?
  result        String    @default("SUCCESS")
  metadata      Json?

  @@index([adminId, timestamp])
  @@index([action, timestamp])
  @@index([targetType, targetId, timestamp])
  @@index([timestamp])
}

model SystemSetting {
  key          String   @id
  value        Json
  category     String
  description  String?
  isSensitive  Boolean  @default(false)
  updatedAt    DateTime @default(now()) @updatedAt
  updatedById  String?

  @@index([category])
}

model Blacklist {
  id           String    @id @default(cuid())
  phoneNumber  String
  phoneHash    String
  type         String
  reason       String?
  source       String?
  userId       String?
  isGlobal     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  createdById  String?
  expiresAt    DateTime?

  @@unique([phoneHash, userId])
  @@index([phoneHash])
  @@index([type])
  @@index([userId])
}

model CreditLedger {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  type            String
  amount          Decimal   @db.Decimal(12, 4)
  balanceAfter    Decimal   @db.Decimal(12, 4)
  referenceType   String?
  referenceId     String?
  description     String
  adminId         String?
  idempotencyKey  String?   @unique
  createdAt       DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([type, createdAt])
}

model RateLimitConfig {
  id              String    @id @default(cuid())
  targetType      String
  targetId        String?
  maxPerSecond    Int?
  maxPerMinute    Int?
  maxPerHour      Int?
  maxPerDay       Int?
  maxPerCampaign  Int?
  maxCostPerDay   Decimal?  @db.Decimal(12, 4)
  maxCostPerMonth Decimal?  @db.Decimal(12, 4)
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  updatedById     String?

  @@index([targetType, targetId])
}

model MessageTemplate {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  name          String
  content       String
  type          String
  status        String    @default("PENDING")
  reviewedById  String?
  reviewedAt    DateTime?
  rejectReason  String?
  variables     String[]  @default([])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId, status])
  @@index([status])
}

model UsdtDeposit {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id])

  usdtAmount      Decimal   @db.Decimal(18, 6)   // 사용자가 입금할 USDT 수량
  exchangeRate    Decimal   @db.Decimal(18, 4)   // 입금 시점 Upbit USDT/KRW 시세 (Lock)
  krwAmount       Decimal   @db.Decimal(18, 0)   // USDT × 환율 = 최종 KRW 충전 금액
  creditAmount    Decimal   @db.Decimal(12, 4)   // 실제 충전될 USD 크레딧 (KRW → USD 환산)

  walletAddress   String                          // 시스템 입금 주소 (TRC20)
  txid            String?   @unique               // 블록체인 트랜잭션 해시 (중복 방지)
  
  status          String    @default("PENDING")   // PENDING, SUBMITTED, VERIFYING, CONFIRMED, FAILED, EXPIRED
  failReason      String?                         // 실패 사유
  
  verifiedAt      DateTime?                       // 검증 완료 시각
  expiresAt       DateTime                        // 입금 요청 만료 시각 (시세 Lock 유효 기간)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId, createdAt])
  @@index([status])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([token])
  @@index([userId])
}

model AddressBook {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  contacts  Contact[]

  @@index([userId, createdAt])
}

model Contact {
  id             String      @id @default(cuid())
  addressBookId  String
  addressBook    AddressBook @relation(fields: [addressBookId], references: [id], onDelete: Cascade)
  name           String?
  nickname       String?
  phone          String
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([addressBookId])
}
