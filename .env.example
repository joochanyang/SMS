# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@host:5434/bulksms"
# 커넥션 풀 상한 (pg Pool.max). 기본 10. 프로덕션은 CPU 코어×2 정도 권장.
DB_POOL_MAX="10"

# Infobip SMS Provider
INFOBIP_API_KEY="your-infobip-api-key"
INFOBIP_URL="https://xxxxx.api-id.infobip.com"
INFOBIP_DLR_SECRET="generate-random-32-char-secret"

# Authentication (NextAuth.js)
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"

# Logging
# 가능한 값: debug, info, warn, error
LOG_LEVEL="info"
# JSON Lines 로그 파일 경로 (선택). 설정 시 console 외 이 경로에도 추가 기록.
# Loki/Promtail, fluent-bit 등 수집기 입력으로 사용.
# LOG_FILE_PATH="/var/log/sovereign-sms/app.log"

# Cron 자동 캠페인 처리 (외부 cron 서비스에서 호출 시 인증용)
CRON_SECRET="generate-with: openssl rand -base64 32"

# Admin Panel Setup (관리자 패널 초기 설정)
# ADMIN_SETUP_SECRET="one-time-admin-setup-secret"

# Telegram 알림 (관리자 패널 알림용, 선택사항)
# TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
# TELEGRAM_CHAT_ID="your-telegram-chat-id"

# SMS.to 발송 throttle (기본값 권장: 8 동시, 400ms 간격)
# 너무 높이면 SMS.to rate limit(약 100 req/sec) 도달 + 통신사 버스트 감지 위험
SMSTO_CONCURRENCY=8
SMSTO_BASE_DELAY_MS=400
SMSTO_JITTER_MS=200
SMSTO_NETWORK_RETRY_MS=3000

# ─────────────────────────────────────────────────────────────────────────────
# TXG-TEL SMS Provider (SMPP 3.4 transceiver)
# ─────────────────────────────────────────────────────────────────────────────
#
# 발송 경로는 SMPP 단일화. HTTP /sendsms, /getreport, push DLR webhook은 폐기됨.
# `sovereign-sms-smpp-worker` 컨테이너가 단독 워커로서 PDU를 송수신하고,
# deliver_sm DLR을 같은 TCP 연결에서 in-band로 받는다.
#
# 잔액 조회만 HTTP /getbalance를 그대로 사용 (SMPP에 잔액 query가 없음).
#
# ⚠️ SMPP 자격증명은 절대 커밋 금지. .env 파일에만 저장.
# ⚠️ 단일 워커 인스턴스만 실행 가능 — 다중 바인드는 TXG 계정 정지 사유.

# SMPP 서버 (TXG가 발급)
TXG_SMPP_HOST=""
TXG_SMPP_PORT="20002"
TXG_SMPP_SYSTEM_ID=""
TXG_SMPP_PASSWORD=""

# HTTP 잔액 조회 (SMPP 호스트와 동일, 포트만 HTTP 20003)
TXG_HTTP_BALANCE_URL=""
# HTTP /getbalance용 자격증명 (SMPP system_id/password와 동일하게 발급되는 것이 일반적)
TXG_HTTP_ACCOUNT=""
TXG_HTTP_PASSWORD=""

# SMPP 옵션 (기본값 권장)
# 동시 in-flight submit_sm 상한. 초과 시 응답 대기 후 다음 PDU 송신.
TXG_SMPP_WINDOW="50"
# submit_sm 응답 timeout (ms). 초과 시 SUBMIT_TIMEOUT으로 종결 (재시도 금지 = 이중과금 방지).
TXG_SMPP_SUBMIT_TIMEOUT_MS="60000"
# enquire_link 주기 (ms). 30초가 SMPP 표준.
TXG_SMPP_ENQUIRE_LINK_MS="30000"
# 워커 폴링 주기 (ms). PENDING 캠페인 행 조회 간격.
TXG_SMPP_POLL_INTERVAL_MS="2000"
# 한 번 폴링에서 처리할 최대 SmsLog 행 수.
TXG_SMPP_BATCH_SIZE="200"

