# Database (Prisma Postgres)
DATABASE_URL="prisma+postgres://localhost:51213/?api_key=..."

# Infobip SMS Provider
INFOBIP_API_KEY="your-infobip-api-key"
INFOBIP_URL="https://xxxxx.api-id.infobip.com"
INFOBIP_DLR_SECRET="generate-random-32-char-secret"

# Authentication (NextAuth.js)
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"

# Admin Setup (remove to disable setup endpoint)
# SETUP_SECRET="one-time-setup-secret"
# ADMIN_EMAIL="admin@sovereign.com"
